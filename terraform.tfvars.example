prefix                = "storage-demo"
region                = "ng-abuja-1"
image_name            = "Ubuntu 22.04 LTS"

# Volumes + Snapshots
volume_size_gb         = 20
volume_type            = "gp-ssd"          # gp-ssd | io-ssd | hdd (region-dependent)
snapshot_after_create  = true

# Required: existing network ID (for the demo VM that mounts the volume)
network_id             = "REPLACE_WITH_YOUR_NETWORK_ID"

# Object Storage — bucket names (final names will be "${prefix}-${name}")
object_buckets         = ["assets", "logs", "backups"]

# File Storage (NFS share)
enable_file_storage    = true
file_storage_size_gb   = 100

# Backups
backup_retention_days  = 7
